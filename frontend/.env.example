# Copy to `.env` and fill in values. Next.js loads `.env`, `.env.local`, `.env.development`, etc.

# Alchemy (optional; non-Hardhat networks in `wagmi.config`)
ALCHEMY_API_KEY=
ALCHEMY_ENDPOINT_URL_BASE_MAINNET=
ALCHEMY_ENDPOINT_URL_BASE_SEPOLIA=
ALCHEMY_ENDPOINT_URL_ETHEREUM_MAINNET=
ALCHEMY_ENDPOINT_URL_ETHEREUM_SEPOLIA=

# Reown — https://dashboard.reown.com (do not use `DUMMY` in production builds)
NEXT_PUBLIC_REOWN_PROJECT_ID=
